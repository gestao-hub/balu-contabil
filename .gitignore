# ─────────────────────────────────────────────────────────────
# .gitignore da RAIZ — apenas itens root-wide / fora do app/.
# O app Next.js tem seu próprio app/.gitignore (build, env, testes).
# ─────────────────────────────────────────────────────────────

# ── Segredos / ambiente (raiz) ───────────────────────────────
.env
.env.local

# ── Export bruto do Bubble (contém PII + tokens — fora do git) ─
# Os slices em bubble-to-prd/slices/ já foram extraídos e estão limpos.
# O arquivo continua no disco; só não vai pro versionamento.
excluviapainel.bubble

# ── Artefatos do Playwright MCP na raiz (snapshots/console — efêmeros) ─
.playwright-mcp/
# Screenshots .png salvos no root pelo playwright MCP (cwd do processo) — efêmeros
/*.png

# ── Claude Code (config local da máquina) ────────────────────
.claude/settings.local.json

# ── Repo de referência clonado (fora do versionamento) ───────
superpowers-kanban/

# ── Kanban local (estado volátil + export auto-gerado) ───────
.kanban/board.json
docs/superpowers/plans/*-board.csv

# ── Imagens/assets de teste (não versionar) ─────────────────
empresa_test.jpeg

# ── Exports de infra (n8n) — contêm secrets/PII, NUNCA versionar ─
docs/n8n/

# ── Caches/deps órfãos na raiz (não há projeto npm aqui) ─────
node_modules/
.vite/

# ── PDFs gerados a partir de .md (artefatos — regeráveis) ────
docs/**/*.pdf

# ── Diversos ─────────────────────────────────────────────────
*.log
.DS_Store
