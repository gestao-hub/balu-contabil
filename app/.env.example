# .env.example — Balu (template; copie para .env.local e preencha)
# .env.local NÃO deve ser commitado (já está no .gitignore).
# Os comentários dizem onde pegar cada chave.
#
# ── NECESSÁRIO PARA A "REVISÃO BALU" (runtime atual) ──────────────────────────

# Base canônica do app (usada pra gerar links de email — confirmação signup,
# reset de senha). NÃO derivar de Host/Origin headers (Host Header Injection).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase principal (auth + cadastros: clientes, empresa, dashboard, notas)
# Dashboard Supabase → Project Settings → API
#   - URL          → "Project URL"
#   - ANON_KEY     → "Project API keys › anon public"
#   - SERVICE_ROLE → "Project API keys › service_role"  (SECRETA — só server-side)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Focus NFe — token de SANDBOX (homologação). Necessário p/ lookup de CNPJ no onboarding.
# Painel Focus NFe → Tokens → ambiente de homologação.
FOCUS_NFE_TOKEN=
# Ambiente do Focus: "hom" (sandbox) ou "prod". Default = hom se vazio/!= prod.
FOCUS_NFE_ENV=hom

# ── PARA PRs FUTUROS (Day 2/3 — não exigido pela revisão de agora) ────────────

# Serpro Integra Contador (geração de DAS — PR 3.2). Trial serve.
# Portal Serpro Integra Contador → suas credenciais de consumidor.
SERPRO_CONSUMER_KEY=
SERPRO_CONSUMER_SECRET=

# n8n motor fiscal (consolidar receitas / RBT12 — PR 3.x).
# Base URL fixa em código: https://webhooks.envia.click
# Segredo HMAC combinado com o n8n.
N8N_WEBHOOK_SECRET=
N8N_WEBHOOK_key=

# ── Declaradas mas o código atual NÃO lê (deixe em branco) ────────────────────
# Supabase "motor fiscal" — reservado p/ acesso direto às tabelas de apuração.
SUPABASE_MOTOR_URL=
SUPABASE_MOTOR_ANON_KEY=
# Chave de criptografia dos certificados A1 (base64, 32 bytes). Gere a sua:
#   openssl rand -base64 32
CERT_ENC_KEY=

# Proteção das rotas de cron (Vercel injeta automaticamente em produção)
CRON_SECRET=

# e-mails de convite/aprovação (Bloco A)
RESEND_API_KEY=
EMAIL_FROM="Balu <noreply@exemplo.com>"
